# Hoimport requests

# رابط التحديث
url = "https://www.duckdns.org/update?domains=Gatecheck&token=58942b91-0ff6-466e-bad7-3940469677b8"

try:
    response = requests.get(url, verify=False, timeout=10)  # verify=False عشان يتجاهل مشاكل الشهادة
    print("DuckDNS response:", response.text)  # هتطلع OK لو اتحدث بنجاح
except Exception as e:
    print("Error:", e)
